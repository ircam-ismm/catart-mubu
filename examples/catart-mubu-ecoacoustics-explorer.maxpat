                        "valueof": {
                            "parameter_enum": [ "basic", "inphase", "maxre", "basicmaxre", "inphasemaxre" ],
                            "parameter_longname": "live.tab[5]",
                            "parameter_mmax": 4,
                            "parameter_modmode": 0,
